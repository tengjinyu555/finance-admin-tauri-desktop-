{
  "name": "finance-admin-vue",
  "private": true,
  "version": "1.0.2",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "start": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "vite build && electron-builder --win",
    "dist": "electron-builder --win --x64"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-vue": "^5.1.12",
    "axios": "^1.18.1",
    "element-plus": "^2.14.2",
    "pinia": "^3.0.4",
    "vue": "^3.5.39",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "concurrently": "^9.2.3",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.0",
    "vite": "^5.4.21",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.finance.admin",
    "productName": "财税管理平台",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "electron/**/*",
      "dist/**/*"
    ],
    "win": {
      "icon": "build/icon_256.png",
      "target": [
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    }
  }
}
